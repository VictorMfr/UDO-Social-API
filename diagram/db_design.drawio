        <mxCell id="bLVtBSfwuI3E0HnndoRf-40" parent="1" style="text;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=12;whiteSpace=wrap;html=1;" value="Cuando creo un mensaje a un usuario nuevo. Se debe crear un registro en la tabla de conversations, registrando la relación entre usuarios. Luego, crea un mensaje asociando la id de dicha conversacion y todos los demas detalles del mensaje.&lt;br&gt;&lt;br&gt;El receptor naturalmente buscara en las conversaciones si aparece su id, y solamente aquellas conversaciones donde aparece&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;, podra modificar el mensaje para que apareza como leido si en el mensaje el sender no es el.&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Si el receptor envia un mensaje, debera crear tambien una nueva conversacion donde el es ahora el sender, y crea un mensaje con el contenido respectivo.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="240" x="40" y="1000" as="geometry" />
        </mxCell>
